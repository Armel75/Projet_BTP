model Invoice {
  id                Int @id @default(autoincrement())
  contract_id       Int
  purchase_order_id Int?
  project_id        Int
  lot_id            Int?
  number            String
  amount            Float
  retention         Float?
  status            String   // DRAFT | SUBMITTED | APPROVED | PAID | CANCELLED
  invoice_date      DateTime   // Date figurant sur la facture (obligatoire, ≠ created_at)
  due_date          DateTime?
  
  // ─── Comptabilité & Paiements ──────────────────────────────────────────
  payment_status       String? // PAID | PARTIAL | CONTESTED | OVERDUE | DUE
  payment_tracking_status String? // PAID | PARTIAL | CONTESTED | OVERDUE | DUE
  supplier_invoice_number String? // Numéro facture côté fournisseur (réconciliation)
  tax_amount           Float? @default(0)
  tax_rate             Float? @default(0)

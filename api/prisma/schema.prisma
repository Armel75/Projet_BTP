  invoice_line_items   String? @db.NVarChar(Max) // JSON snapshot des lignes facturées
  export_format_url    String? // URL export EDI/XML compta
  dispute_reason       String? @db.NVarChar(Max) // Motif contestation si CONTESTED

  tenant_id         Int
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  created_by Int?
  createdBy  User? @relation("InvoiceCreatedBy", fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)




  contract      Contract       @relation(fields: [contract_id],       references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchase_order_id], references: [id])
  project       Project        @relation(fields: [project_id],        references: [id], onUpdate: NoAction, onDelete: NoAction)
  tenant        Tenant         @relation(fields: [tenant_id],         references: [id], onUpdate: NoAction, onDelete: NoAction)
  lot           ProjectLot?    @relation(fields: [lot_id],            references: [id], onUpdate: NoAction, onDelete: NoAction)
    
  payments Payment[]

  @@index([tenant_id, project_id])
  @@index([status])
  @@index([created_at])
  @@index([purchase_order_id])
  @@index([lot_id])
  @@index([payment_tracking_status])
  }
  


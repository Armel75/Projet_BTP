generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}


model ResourceType {
  id   Int @id @default(autoincrement())
  code String @unique // LABOR, EQUIPMENT, SUBCONTRACTOR

  resources Resource[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

//////////////////////////////
// CORE + MULTI TENANT
//////////////////////////////

model Tenant {
  id   Int @id @default(autoincrement())
  name String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  projects Project[]
  users    User[]

  resources Resource[]
  projectLots ProjectLot[]
  wbsNodes WBSNode[]
  tasks Task[]
  taskAssignments TaskAssignment[]
  suppliers Supplier[]
  tenders Tender[]
  purchaseOrders PurchaseOrder[]
  deliveries Delivery[]
  inventoryItems InventoryItem[]
  goodsReceiptItems GoodsReceiptItem[]
  contracts Contract[]
  contractLineItems ContractLineItem[]
  changeOrders ChangeOrder[]
  rfis RFI[]
  submittals Submittal[]
  budgetLines BudgetLine[]
  invoices Invoice[]
  payments Payment[]
  controlReports ControlReport[]
  workAcceptances WorkAcceptance[]
  incidents Incident[]
  documents Document[]
  documentVersions DocumentVersion[]
  photos Photo[]
  documentExchanges DocumentExchange[]
  workflowActions WorkflowAction[]
  auditLogs AuditLog[]
  dailyLogs DailyLog[]
  inspections Inspection[]
  punchItems PunchItem[]
  meetings Meeting[]
  costTransactions CostTransaction[]
  workflowDefinitions WorkflowDefinition[]
  workflowSteps WorkflowStep[]
  workflowTransitions WorkflowTransition[]
  workflowInstances WorkflowInstance[]
  materialConsumptions MaterialConsumption[]
  goodsReceipts GoodsReceipt[]
  weeklyReports WeeklyReport[]
  roles     Role[]
  userRoles UserRole[]

  // ─── Intégration GLPI ──────────────────────────────────────
  glpiUsers GLPIUser[]
  tickets   Ticket[]
}

model User {
  id            Int @id @default(autoincrement())
  firstname     String
  lastname      String
  email         String @unique
  password_hash String
  username      String @unique
  matricule     String @unique
  status        String
  failedLogins  Int    @default(0)
  lastLoginAt   DateTime?

  phone         String?

  tenant_id     Int

  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  auditLogs        AuditLog[]
  rfiSubmitted     RFI[] @relation("RfiSubmittedBy")
  rfiAssigned      RFI[] @relation("RfiAssignedTo")
  meetingAttendances MeetingAttendee[]
  createdProjects Project[] @relation("ProjectCreatedBy")
  preparedReports  WeeklyReport[] @relation("PreparedBy")
  validatedReports WeeklyReport[] @relation("ValidatedBy")
  userRoles UserRole[]

  // =========================
  // CREATED_BY INVERSES (AJOUT)
  // =========================

  taskCreatedTasks Task[] @relation("TaskCreatedBy")
  taskAssignmentsCreated TaskAssignment[] @relation("TaskAssignmentCreatedBy")

  suppliersCreated Supplier[]
  tendersCreated Tender[] @relation("TenderCreatedBy")
  tenderBidsCreated TenderBid[] @relation("TenderBidCreatedBy")

  purchaseOrdersCreated PurchaseOrder[]
  deliveriesCreated Delivery[]

  inventoryItemsCreated InventoryItem[]
  projectStocksCreated ProjectStock[]

  goodsReceiptsCreated GoodsReceipt[]
  goodsReceiptItemsCreated GoodsReceiptItem[]

  stockMovementsCreated StockMovement[]
  materialConsumptionsCreated MaterialConsumption[]

  contractsCreated         Contract[]         @relation("ContractCreatedBy")
  contractsApproved        Contract[]         @relation("ContractApprovedBy")
  contractLineItemsCreated ContractLineItem[] @relation("ContractLineItemCreatedBy")
  changeOrdersCreated ChangeOrder[] @relation("ChangeOrderCreatedBy")

  invoicesCreated Invoice[] @relation("InvoiceCreatedBy")
  paymentsCreated Payment[] @relation("PaymentCreatedBy")

  controlReportsCreated ControlReport[] @relation("ControlReportCreatedBy")
  workAcceptancesCreated WorkAcceptance[] @relation("WorkAcceptanceCreatedBy")

  incidentsCreated   Incident[] @relation("IncidentCreatedBy")
  incidentsAssigned  Incident[] @relation("IncidentAssignedTo")

  documentsCreated Document[] @relation("DocumentCreatedBy")
  documentExchangesCreated DocumentExchange[] @relation("DocumentExchangeCreatedBy")
  documentVersionsCreated DocumentVersion[] @relation("DocumentVersionCreatedBy")

  workflowDefinitionsCreated WorkflowDefinition[] @relation("WorkflowDefinitionCreatedBy")
  workflowActionsPerformed WorkflowAction[] @relation("WorkflowActionPerformed")

  dailyLogsCreated DailyLog[] @relation("DailyLogCreatedBy")
  inspectionsCreated   Inspection[] @relation("InspectionCreatedBy")
  inspectionsAssigned  Inspection[] @relation("InspectionInspector")
  punchItemsCreated   PunchItem[] @relation("PunchItemCreatedBy")
  punchItemsAssigned  PunchItem[] @relation("PunchItemAssignedTo")
  meetingsCreated Meeting[] @relation("MeetingCreatedBy")

  costTransactionsCreated CostTransaction[] @relation("CostTransactionCreatedBy")
  weeklyReportsCreated WeeklyReport[] @relation("WeeklyReportCreatedBy")

  // ─── Lots corps d'état ──────────────────────────────────────────
  lotsResponsible ProjectLot[] @relation("LotResponsible")

  // ─── Gestion de projets ──────────────────────────────────────────
  managedProjects          Project[]        @relation("ProjectManager")
  workAcceptancesInspected WorkAcceptance[] @relation("WorkAcceptanceInspector")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Sessions pour authentification stateful
  sessions Session[]
}

//////////////////////////////
// AUTH SESSIONS (SECURE)
//////////////////////////////

model Session {
  id         String   @id @default(uuid())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  expiresAt  DateTime
  ip         String?
  userAgent  String?
  revoked    Boolean  @default(false)
  // Pour audit et multi-device
  device     String?
  // Indexes pour perf et sécurité
  @@index([userId])
  @@index([expiresAt])
}

//////////////////////////////
// GLPI INTEGRATION
//////////////////////////////

model GLPIUser {
  id                    Int      @id @default(autoincrement())
  tenant_id             Int
  tenant                Tenant   @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  glpi_id               Int      // ID interne GLPI (stable, utilisé pour l'upsert)
  login                 String?
  email                 String?
  first_name            String?
  last_name             String?
  full_name             String?
  phone                 String?
  department_name       String?  // Nom du département GLPI (non FK, syncé tel quel)
  entity_name           String?  // Entité GLPI

  status                String   @default("ACTIVE")  // ACTIVE | INACTIVE | DELETED
  is_deleted_in_source  Boolean  @default(false)     // true si supprimé dans GLPI
  source_updated_at     DateTime?                    // date_mod côté GLPI
  last_synced_at        DateTime?                    // dernière synchro réussie
  sync_status           String   @default("SYNCED")  // SYNCED | ERROR | PENDING
  raw_payload           String?  @db.NVarChar(Max)   // payload JSON brut GLPI pour debug

  requested_tickets Ticket[] @relation("TicketRequesterGLPIUser")
  assigned_tickets  Ticket[] @relation("TicketAssigneeGLPIUser")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([tenant_id, glpi_id])
  @@index([tenant_id, email])
  @@index([tenant_id, login])
  @@index([tenant_id, status])
}

model Ticket {
  id          Int    @id @default(autoincrement())
  tenant_id   Int
  tenant      Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  glpi_id       Int     // ID interne GLPI (stable, utilisé pour l'upsert)
  ticket_number String?                  // Numéro affiché dans GLPI (ex: "TKT-4521")
  title         String                   // Titre du ticket (NOT NULL, toujours présent dans GLPI)
  description   String? @db.NVarChar(Max)

  ticket_type   String?                  // INCIDENT | REQUEST
  status        String  @default("OPEN") // OPEN | IN_PROGRESS | PENDING | RESOLVED | CLOSED
  priority      String?                  // 1 Very High ... 6 Very Low (valeur brute GLPI)
  urgency       String?                  // idem
  impact        String?                  // idem

  category_name  String?                 // Nom de la catégorie GLPI
  entity_name    String?                 // Entité GLPI
  location_name  String?                 // Localisation GLPI

  opened_at   DateTime?
  due_at      DateTime?
  resolved_at DateTime?
  closed_at   DateTime?

  requester_glpi_user_id Int?
  requester_glpi_user    GLPIUser? @relation("TicketRequesterGLPIUser", fields: [requester_glpi_user_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  assignee_glpi_user_id Int?
  assignee_glpi_user    GLPIUser? @relation("TicketAssigneeGLPIUser", fields: [assignee_glpi_user_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  source_updated_at DateTime?                   // date_mod côté GLPI
  last_synced_at    DateTime?                   // dernière synchro réussie
  sync_status       String   @default("SYNCED") // SYNCED | ERROR | PENDING
  raw_payload       String?  @db.NVarChar(Max)  // payload JSON brut GLPI pour debug

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([tenant_id, glpi_id])
  @@index([tenant_id, status])
  @@index([tenant_id, ticket_number])
  @@index([requester_glpi_user_id])
  @@index([assignee_glpi_user_id])
}

//////////////////////////////
// RESOURCES
//////////////////////////////

model Resource {
  id        Int @id @default(autoincrement())
  tenant_id Int

  name String
  type_id Int

  cost_rate Float

  tenant Tenant @relation(fields: [tenant_id], references: [id])
  type   ResourceType @relation(fields: [type_id], references: [id])

  assignments TaskAssignment[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

//////////////////////////////
// PROJECT
//////////////////////////////

model Project {
  id           Int @id @default(autoincrement())
  code         String @unique
  title        String @db.NVarChar(Max)
  description  String? @db.NVarChar(Max)
  status       String
  phase        String @default("PREPARATION") // ETUDE | PREPARATION | EXECUTION | RECEPTION | CLOTURE
  client_name  String?

  tenant_id          Int
  created_by         Int
  document_id        Int
  project_manager_id Int?  // Chef de projet

  tenant         Tenant   @relation(fields: [tenant_id],          references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy      User     @relation("ProjectCreatedBy",            fields: [created_by],         references: [id], onDelete: NoAction, onUpdate: NoAction)
  document       Document @relation("ProjectMainDocument",         fields: [document_id],        references: [id], onDelete: NoAction, onUpdate: NoAction)
  projectManager User?    @relation("ProjectManager",              fields: [project_manager_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  start_date DateTime?
  end_date   DateTime?

  budget_initial Float
  currency       String
  location       String

  lots     ProjectLot[]
  wbs      WBSNode[]
  documents Document[]
  workflowInstances WorkflowInstance[]
  incidents Incident[]
  tenders   Tender[]

  goodsReceiptItems GoodsReceiptItem[]
  tasks Task[]
  purchaseOrders PurchaseOrder[]
  deliveries Delivery[]
  projectStocks ProjectStock[]
  goodsReceipts GoodsReceipt[]
  stockMovements StockMovement[]
  materialConsumptions MaterialConsumption[]
  contracts Contract[]
  changeOrders ChangeOrder[]
  rfis RFI[]
  submittals Submittal[]
  budgetLines BudgetLine[]
  invoices Invoice[]
  controlReports ControlReport[]
  workAcceptances WorkAcceptance[]
  photos Photo[]
  documentExchanges DocumentExchange[]
  dailyLogs DailyLog[]
  inspections Inspection[]
  punchItems PunchItem[]
  meetings Meeting[]
  costTransactions CostTransaction[]
  weeklyReports WeeklyReport[]
  userRoles UserRole[]
  }

  //////////////////////////////
  // TRADE CATEGORIES (catalogue BTP)
  //////////////////////////////

  model TradeCategory {
    code  String @id  // ex: "GROS_OEUVRE", "ELECTRICITE_CFO_CFA"
    label String      // ex: "Gros Œuvre", "Électricité CFO/CFA"
    order Int         @default(0)

    lots ProjectLot[]
  }

  //////////////////////////////
  // PROJECT LOT
  //////////////////////////////

  model ProjectLot {
    id          Int    @id @default(autoincrement())
    project_id  Int
    name        String
    description String? @db.NVarChar(Max)
    tenant_id   Int

    // ─── Corps d'état ────────────────────────────────────────────────────
    lot_number       String           // Numéro officiel du lot : "01", "02", "A"...
    trade_code       String           // FK → TradeCategory.code
    status           String           @default("CONCEPTION")
    // CONCEPTION | APPEL_OFFRES | ATTRIBUTION | EN_COURS
    // RECEPTION_PROVISOIRE | RECEPTION_DEFINITIVE | CLOS
    budget_allocated Float            @default(0)  // Budget alloué à ce lot
    progress         Float            @default(0)  // Avancement 0–100

    // ─── Données optionnelles (disponibles après attribution) ─────────────
    start_date     DateTime?
    end_date       DateTime?
    responsible_id Int?       // Chef de lot (User)
    contractor_id  Int?       // Entrepreneur principal (Supplier)
    contract_id    Int?       // Contrat de sous-traitance lié (Contract)

    // ─── Relations ───────────────────────────────────────────────────────
    tenant      Tenant        @relation(fields: [tenant_id],     references: [id],   onUpdate: NoAction, onDelete: NoAction)
    project     Project       @relation(fields: [project_id],    references: [id],   onUpdate: NoAction, onDelete: NoAction)
    trade       TradeCategory @relation(fields: [trade_code],    references: [code], onUpdate: NoAction, onDelete: NoAction)
    responsible User?         @relation("LotResponsible",        fields: [responsible_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
    contractor  Supplier?     @relation("LotContractor",         fields: [contractor_id],  references: [id], onUpdate: NoAction, onDelete: NoAction)
    contract    Contract?     @relation("LotContract",           fields: [contract_id],    references: [id], onUpdate: NoAction, onDelete: NoAction)

    // ─── Inverses ─────────────────────────────────────────────────────────
    wbsNodes        WBSNode[]
    tasks           Task[]
    budgetLines     BudgetLine[]
    inspections     Inspection[]
    punchItems      PunchItem[]
    documents       Document[]
    tenders         Tender[]
    changeOrders      ChangeOrder[]
    contractLineItems ContractLineItem[]
    incidents         Incident[]
    workAcceptances   WorkAcceptance[]
    controlReports  ControlReport[]
    purchaseOrders  PurchaseOrder[]
    invoices        Invoice[]

    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    @@unique([project_id, lot_number])
    @@index([project_id, trade_code])
    @@index([project_id, status])
  }

//////////////////////////////
// WBS
//////////////////////////////

model WBSNode {
  id         Int @id @default(autoincrement())
  project_id Int
  parent_id  Int?
  tenant_id  Int
  lot_id     Int?
  code  String
  name  String
  level Int

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  project Project  @relation(fields: [project_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  parent  WBSNode? @relation("WBSParent", fields: [parent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children WBSNode[] @relation("WBSParent")
  lot     ProjectLot? @relation(fields: [lot_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tasks   Task[]
  tenders Tender[] // ✅ INVERSE

  // Relations inverses pour corriger les erreurs Prisma
  contractLineItems ContractLineItem[]
  budgetLines       BudgetLine[]
  costTransactions  CostTransaction[]

  @@index([tenant_id, project_id])
  @@index([project_id, parent_id])
  @@index([lot_id])
}

//////////////////////////////
// TASKS
//////////////////////////////

model Task {
    incidents  Incident[]
    punchItems PunchItem[]
  id         Int @id @default(autoincrement())
  project_id Int
  wbs_id     Int?
  lot_id     Int?

  title       String
  description String? @db.NVarChar(Max)
  status      String
  priority    String  @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  progress    Float
  tenant_id   Int

  planned_start DateTime?
  planned_end   DateTime?
  actual_start  DateTime?
  actual_end    DateTime?
  materialConsumptions MaterialConsumption[]
  created_by Int?
  createdBy  User? @relation("TaskCreatedBy", fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
  tenant  Tenant   @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  project Project  @relation(fields: [project_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  wbs     WBSNode? @relation(fields: [wbs_id], references: [id])
  lot     ProjectLot? @relation(fields: [lot_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  dependencies TaskDependency[] @relation("TaskDependency_task")
  dependents   TaskDependency[] @relation("TaskDependency_dependsOn")
  assignments  TaskAssignment[]
  controlReports ControlReport[]
  weeklyReportItems WeeklyReportItem[]

  @@index([tenant_id, project_id])
  @@index([tenant_id, status])
  @@index([project_id, wbs_id])
  @@index([lot_id])
}

model TaskAssignment {
  id          Int @id @default(autoincrement())
  task_id     Int
  resource_id Int

  planned_hours Float
  actual_hours  Float?

  start_date DateTime?
  end_date   DateTime?

  tenant_id Int
  created_by Int?
  createdBy  User? @relation("TaskAssignmentCreatedBy", fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)

  task     Task     @relation(fields: [task_id], references: [id])
  resource Resource @relation(fields: [resource_id], references: [id])
  tenant   Tenant   @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@index([tenant_id, task_id])
  @@index([tenant_id, resource_id])
}


model TaskDependency {
  id           Int @id @default(autoincrement())
  task_id      Int
  depends_on_id Int
  task         Task @relation("TaskDependency_task", fields: [task_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  dependsOn    Task @relation("TaskDependency_dependsOn", fields: [depends_on_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}


//////////////////////////////
// APPROVISIONNEMENT COMPLET
//////////////////////////////

model Supplier {
  id           Int    @id @default(autoincrement())
  tenant_id    Int
  name         String
  email        String?                       // Email du contact principal
  phone        String?                       // Téléphone
  address      String? @db.NVarChar(Max)     // Adresse complète
  siret        String?                       // SIRET / RCCM / NIF selon le pays
  contact_name String?                       // Nom du responsable commercial
  status       String  @default("ACTIVE")    // ACTIVE | INACTIVE | BLACKLISTED
  specialty    String?                       // Corps d'état principal

  tenant Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  budgetLines BudgetLine[]
  tenders         TenderBid[]
  tendersAwarded  Tender[] @relation("TenderAwardedSupplier")
  purchaseOrders  PurchaseOrder[]
  contracts       Contract[]
  deliveries Delivery[] // ✅ INVERSE
  lots       ProjectLot[] @relation("LotContractor")

  created_by   Int
  createdBy    User @relation(fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
}

model Tender {
  id              Int @id @default(autoincrement())
  project_id      Int
  lot_id          Int?
  wbs_id          Int?
  reference       String?           // AO-2026-001
  title           String
  description     String? @db.NVarChar(Max)
  type            String  @default("OPEN")     // OPEN | RESTRICTED | NEGOTIATED
  category        String  @default("TRAVAUX")  // TRAVAUX | FOURNITURES | SERVICES | MOE
  status          String  @default("DRAFT")    // DRAFT | PUBLISHED | EVALUATION | AWARDED | CANCELLED | CLOSED
  tenant_id       Int
  currency        String  @default("EUR")
  budget_estimate     Float?
  submission_deadline DateTime?
  opening_date        DateTime?
  award_date          DateTime?
  awarded_supplier_id Int?
  document_url        String?
  notes               String? @db.NVarChar(Max)

  wbs             WBSNode?    @relation(fields: [wbs_id],              references: [id])
  project         Project     @relation(fields: [project_id],          references: [id], onUpdate: NoAction, onDelete: NoAction)
  tenant          Tenant      @relation(fields: [tenant_id],           references: [id], onUpdate: NoAction, onDelete: NoAction)
  lot             ProjectLot? @relation(fields: [lot_id],              references: [id], onUpdate: NoAction, onDelete: NoAction)
  awardedSupplier Supplier?   @relation("TenderAwardedSupplier",       fields: [awarded_supplier_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  bids            TenderBid[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([wbs_id])
  @@index([lot_id])
  @@index([awarded_supplier_id])

  created_by   Int
  createdBy    User @relation("TenderCreatedBy", fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
}

model TenderBid {
  id          Int @id @default(autoincrement())
  tender_id   Int
  supplier_id Int
  amount      Float
  status      String  @default("SUBMITTED") // SUBMITTED | EVALUATED | ACCEPTED | REJECTED | WITHDRAWN
  technical_score Float?
  financial_score Float?
  total_score     Float?
  rank            Int?
  submitted_at    DateTime?
  document_url    String?
  is_compliant    Boolean  @default(true)
  validity_period Int?     // jours
  notes           String?  @db.NVarChar(Max)

  tender   Tender   @relation(fields: [tender_id],   references: [id], onUpdate: NoAction, onDelete: NoAction)
  supplier Supplier @relation(fields: [supplier_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([supplier_id])
  @@index([tender_id])

  created_by   Int
  createdBy    User @relation("TenderBidCreatedBy", fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
}

model PurchaseOrder {
  id             Int    @id @default(autoincrement())
  project_id     Int
  supplier_id    Int
  tenant_id      Int
  lot_id         Int?
  number         String?          // Numéro du bon de commande (ex: BC-2026-001)
  title          String?          // Objet du bon de commande
  total_amount   Float  @default(0) // Montant total du BC
  status         String
  currency       String
  delivery_date  DateTime?        // Date de livraison prévue
  notes          String? @db.NVarChar(Max)

  project  Project     @relation(fields: [project_id],  references: [id], onUpdate: NoAction, onDelete: NoAction)
  tenant   Tenant      @relation(fields: [tenant_id],   references: [id], onUpdate: NoAction, onDelete: NoAction)
  supplier Supplier    @relation(fields: [supplier_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  lot      ProjectLot? @relation(fields: [lot_id],      references: [id], onUpdate: NoAction, onDelete: NoAction)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  goodsReceipts GoodsReceipt[]
  invoices      Invoice[]

  @@index([tenant_id, project_id])
  @@index([tenant_id, supplier_id])
  @@index([tenant_id, status])
  @@index([lot_id])

    created_by   Int
    createdBy    User @relation(fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
}

model Delivery {
  id          Int @id @default(autoincrement())
  project_id  Int
  supplier_id Int   // ✅ AJOUT
  type        String // INTERNAL / EXTERNAL
  status      String
  tenant_id   Int

  supplier Supplier @relation(fields: [supplier_id], references: [id]) // ✅
  project Project @relation(fields: [project_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  tenant Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  delivered_at DateTime?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([supplier_id])
    created_by   Int
    createdBy    User @relation(fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
  }

model InventoryItem {
  id          Int    @id @default(autoincrement())
  tenant_id   Int
  code        String?                     // Code article interne (ex: MAT-001)
  name        String
  description String? @db.NVarChar(Max)
  unit        String                      // kg, m3, piece, ml...
  category    String?                     // MATERIAL | EQUIPMENT | CONSUMABLE | CHEMICAL
  unit_cost   Float?                      // Coût unitaire de référence

  created_at DateTime @default(now())
  tenant Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  updated_at DateTime @updatedAt

  projectStocks ProjectStock[]
  goodsReceiptItems GoodsReceiptItem[]
  stockMovements StockMovement[]
  materialConsumptions MaterialConsumption[]

    created_by   Int
    createdBy    User @relation(fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)

}


model ProjectStock {
  id         Int @id @default(autoincrement())
  project_id Int
  item_id    Int
  document_id Int?
  quantity   Float

  project Project @relation(fields: [project_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  item    InventoryItem @relation(fields: [item_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  document Document?     @relation(fields: [document_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  costTransactions CostTransaction[]
  @@unique([project_id, item_id])

    created_by   Int
    createdBy    User @relation(fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
}


model GoodsReceipt {
  id          Int @id @default(autoincrement())
  project_id  Int
  order_id    Int
  received_at DateTime
  tenant_id   Int
  tenant  Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  project Project @relation(fields: [project_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  order   PurchaseOrder @relation(fields: [order_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  items GoodsReceiptItem[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([tenant_id, project_id])
  @@index([project_id, order_id])

    created_by   Int
    createdBy    User @relation(fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
}


model GoodsReceiptItem {
  id          Int @id @default(autoincrement())
  receipt_id  Int
  item_id     Int
  tenant_id   Int
  document_id Int?
  quantity_ordered Float
  quantity_received Float
  quantity_rejected Float?

  project_id Int
  project Project @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  receipt GoodsReceipt @relation(fields: [receipt_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  item    InventoryItem @relation(fields: [item_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  tenant  Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  document Document?     @relation(fields: [document_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([tenant_id, project_id])
  @@index([receipt_id, item_id])

    created_by   Int
    createdBy    User @relation(fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
}


model StockMovement {
  id         Int @id @default(autoincrement())
  project_id Int
  item_id    Int

  type String // IN / OUT / TRANSFER
  quantity Float
  document_id Int?

  source_type String // DELIVERY / TASK / ADJUSTMENT
  source_id   String

  created_at DateTime @default(now())

  materialConsumptions MaterialConsumption[] // ✅ INVERSE

  project Project @relation(fields: [project_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  item    InventoryItem @relation(fields: [item_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  document Document?    @relation(fields: [document_id], references: [id], onUpdate: NoAction, onDelete: NoAction)


  updated_at DateTime @updatedAt

  @@index([project_id, created_at])
  @@index([project_id, item_id])

    created_by   Int
    createdBy    User @relation(fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
}


model MaterialConsumption {
  id         Int @id @default(autoincrement())
  project_id Int
  task_id    Int?
  stock_movement_id Int? // ✅ AJOUT
  item_id    Int
  document_id Int?
  quantity Float
  tenant_id   Int

  project Project @relation(fields: [project_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  task    Task?   @relation(fields: [task_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  item    InventoryItem @relation(fields: [item_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  document Document?     @relation(fields: [document_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  tenant  Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  stockMovement StockMovement? @relation(fields: [stock_movement_id], references: [id]) // ✅
  
  created_at DateTime @default(now())

  @@index([tenant_id, project_id])
  @@index([project_id, item_id])
  @@index([task_id, item_id])
  @@index([stock_movement_id])

    created_by   Int
    createdBy    User @relation(fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
}

  //////////////////////////////
  // CONTRACTS & CHANGE MANAGEMENT
  //////////////////////////////

  model Contract {
    id             Int @id @default(autoincrement())
    project_id     Int
    supplier_id    Int
    type           String    // OWNER | SUBCONTRACT | SUPPLY | CONSULTING
    title          String                        // Intitulé / objet du marché (obligatoire)
    reference      String
    description    String?   @db.NVarChar(Max)   // Objet détaillé du marché
    category       String?                       // TRAVAUX | FOURNITURES | SERVICES | MOE | ETUDES
    status         String    // DRAFT | PENDING_SIGNATURE | APPROVED | EXECUTED | SUSPENDED | TERMINATED | CLOSED
    amount         Decimal   @db.Decimal(15, 2) @default(0)  // Montant initial du contrat
    signed_at      DateTime?                     // Date de signature
    executed_at    DateTime?
    start_date     DateTime?
    end_date       DateTime?
    retention_pct  Float?

    advance_payment_pct    Float?                // % d'avance forfaitaire (pratique BTP)
    advance_payment_amount Decimal? @db.Decimal(15, 2)  // Montant de l'avance versée
    price_revision_index   String?               // Indice de révision des prix (BT01, TP01, ICC...)
    payment_terms          Int?                  // Délai de paiement légal en jours (30, 45...)
    document_url           String?               // URL du contrat signé (PDF scanné)

    approved_by        Int?
    approved_at        DateTime?
    terminated_at      DateTime?
    termination_reason String? @db.NVarChar(Max)

    currency       String
    tenant_id      Int

    supplier   Supplier @relation(fields: [supplier_id], references: [id])
    tenant     Tenant   @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
    project    Project  @relation(fields: [project_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
    approvedBy User?    @relation("ContractApprovedBy", fields: [approved_by], references: [id], onUpdate: NoAction, onDelete: NoAction)

    line_items    ContractLineItem[]
    change_orders ChangeOrder[]
    invoices      Invoice[]
    lots          ProjectLot[] @relation("LotContract")
    created_by Int?
    createdBy  User? @relation("ContractCreatedBy", fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)

    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    @@index([tenant_id, project_id])
    @@index([status])
    @@index([created_at])
    @@index([supplier_id])
  }


  model ContractLineItem {
    id          Int @id @default(autoincrement())
    contract_id Int
    wbs_id      Int?
    lot_id      Int?
    order_index Int     @default(0)              // Numérotation et ordre d'affichage
    description String  @db.NVarChar(Max)
    category    String?                          // Corps d'état / nature de prestation
    quantity    Decimal @db.Decimal(15, 4) @default(0)
    unit        String
    unit_price  Decimal @db.Decimal(15, 2) @default(0)
    total_price Decimal @db.Decimal(15, 2) @default(0)

    progress_pct  Float   @default(0)            // Avancement de la ligne (0–100)
    billed_amount Decimal @db.Decimal(15, 2) @default(0)  // Montant déjà facturé sur cette ligne

    tenant_id  Int
    status     String   // APPROVED | PENDING_APPROVAL | REJECTED
    created_by Int?

    tenant    Tenant      @relation(fields: [tenant_id],   references: [id])
    contract  Contract    @relation(fields: [contract_id], references: [id])
    wbs_node  WBSNode?    @relation(fields: [wbs_id],      references: [id])
    lot       ProjectLot? @relation(fields: [lot_id],      references: [id], onUpdate: NoAction, onDelete: NoAction)
    createdBy User?       @relation("ContractLineItemCreatedBy", fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)

    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    @@index([contract_id])
    @@index([lot_id])
  }

  model ChangeOrder {
    id          Int @id @default(autoincrement())
    project_id  Int
    contract_id Int
    lot_id      Int?
    number      String
    title       String                        // Objet de l'OdS (obligatoire en BTP)
    reason      String? @db.NVarChar(Max)     // Motif / cause
    description String  @db.NVarChar(Max)
    status      String  // "PENDING_APPROVAL" | "APPROVED" | "REJECTED"
    amount      Float
    impact_days Int?                          // Impact sur le planning (jours)
    approved_at DateTime?
    tenant_id   Int
    created_by  Int?
    createdBy   User?       @relation("ChangeOrderCreatedBy",  fields: [created_by],  references: [id], onUpdate: NoAction, onDelete: NoAction)
    tenant      Tenant      @relation(fields: [tenant_id],      references: [id], onUpdate: NoAction, onDelete: NoAction)
    project     Project     @relation(fields: [project_id],     references: [id], onUpdate: NoAction, onDelete: NoAction)
    contract    Contract    @relation(fields: [contract_id],    references: [id], onUpdate: NoAction, onDelete: NoAction)
    lot         ProjectLot? @relation(fields: [lot_id],         references: [id], onUpdate: NoAction, onDelete: NoAction)
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt
    @@index([lot_id])
  }

    //////////////////////////////
    // RFI & SUBMITTALS
    //////////////////////////////

    model RFI {
      id          Int @id @default(autoincrement())
      project_id  Int
      tenant_id   Int

      number      String
      subject     String @db.NVarChar(Max)
      question    String @db.NVarChar(Max)
      answer      String? @db.NVarChar(Max)
      status      String // OPEN, ANSWERED, CLOSED
      submitted_by Int? // user_id
      assigned_to Int? // user_id

      submittedBy User?  @relation("RfiSubmittedBy", fields: [submitted_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
      assignedTo  User?  @relation("RfiAssignedTo", fields: [assigned_to], references: [id], onDelete: NoAction, onUpdate: NoAction)
      
      tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
      project Project @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

      created_at DateTime @default(now())
      updated_at DateTime @updatedAt

      @@index([tenant_id, project_id])
      @@index([status])
      @@index([created_at])
    }

    model Submittal {
      id               Int @id @default(autoincrement())
      project_id       Int
      type             String // "MATERIAL_SUBMITTAL", "SHOP_DRAWING", "SAMPLE"
      title            String
      specification_ref String?
      status           String // "SUBMITTED", "APPROVED", "APPROVED_AS_NOTED", "REJECTED"
      due_date         DateTime?
      submission_date  DateTime?
      response_date    DateTime?
      tenant_id        Int

      tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
      project Project    @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

      items SubmittalItem[]
      created_at DateTime @default(now())
      updated_at DateTime @updatedAt

      @@index([tenant_id, project_id])
      @@index([status])
      @@index([created_at])
    }

    model SubmittalItem {
      id          Int @id @default(autoincrement())
      submittal_id Int
      description  String @db.NVarChar(Max)
      document_url String?  // lien vers Document

  submittal Submittal @relation(fields: [submittal_id], references: [id])
}

//////////////////////////////
// FINANCE / BUDGET
//////////////////////////////

model BudgetLine {
  id          Int @id @default(autoincrement())
  project_id  Int
  wbs_id      Int?
  lot_id      Int?
  category    String
  planned     Float
  currency    String
  tenant_id   Int
  supplier_id Int?
  actual      Float // calculé à partir des engagements

  wbs     WBSNode?   @relation(fields: [wbs_id],     references: [id], onUpdate: NoAction, onDelete: NoAction)
  lot     ProjectLot? @relation(fields: [lot_id],    references: [id], onUpdate: NoAction, onDelete: NoAction)
  project Project    @relation(fields: [project_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  supplier Supplier? @relation(fields: [supplier_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  controlReports ControlReport[]
  tenant  Tenant     @relation(fields: [tenant_id],  references: [id], onUpdate: NoAction, onDelete: NoAction)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([lot_id])
}

model Invoice {
  id                Int @id @default(autoincrement())
  contract_id       Int
  purchase_order_id Int?
  project_id        Int
  lot_id            Int?
  number            String
  amount            Float
  retention         Float?
  status            String   // DRAFT | SUBMITTED | APPROVED | PAID | CANCELLED
  invoice_date      DateTime   // Date figurant sur la facture (obligatoire, ≠ created_at)
  due_date          DateTime?
  tenant_id         Int

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  created_by Int?
  createdBy  User? @relation("InvoiceCreatedBy", fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)

  contract      Contract       @relation(fields: [contract_id],       references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchase_order_id], references: [id])
  project       Project        @relation(fields: [project_id],        references: [id], onUpdate: NoAction, onDelete: NoAction)
  tenant        Tenant         @relation(fields: [tenant_id],         references: [id], onUpdate: NoAction, onDelete: NoAction)
  lot           ProjectLot?    @relation(fields: [lot_id],            references: [id], onUpdate: NoAction, onDelete: NoAction)
    
  payments Payment[]

  @@index([tenant_id, project_id])
  @@index([status])
  @@index([created_at])
  @@index([purchase_order_id])
  @@index([lot_id])
  }
  

model Payment {
  id         Int @id @default(autoincrement())
  invoice_id Int
  amount     Float
  date       DateTime
  tenant_id  Int
  method     String? // WIRE, CHECK
  created_by Int?
  createdBy  User? @relation("PaymentCreatedBy", fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)

  tenant Tenant @relation(fields: [tenant_id], references: [id])
  invoice    Invoice @relation(fields: [invoice_id], references: [id])
  created_at DateTime @default(now())
}

//////////////////////////////
// QUALITY / CONTROL
//////////////////////////////

model ControlReport {
  id          Int @id @default(autoincrement())
  project_id  Int
  task_id     Int?
  lot_id      Int?
  tenant_id   Int
  title       String?
  type        String  @default("QUALITY") // QUALITY | SAFETY | COMPLIANCE | TECHNICAL
  status      String
  report_date DateTime?
  comment     String @db.NVarChar(Max)

  budgetLines BudgetLine[]
  created_by  Int?
  createdBy   User?       @relation("ControlReportCreatedBy", fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)

  project Project     @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant  Tenant      @relation(fields: [tenant_id],  references: [id], onDelete: NoAction, onUpdate: NoAction)
  task    Task?       @relation(fields: [task_id],    references: [id], onDelete: NoAction, onUpdate: NoAction)
  lot     ProjectLot? @relation(fields: [lot_id],     references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([lot_id])
}

model WorkAcceptance {
  id         Int @id @default(autoincrement())
  project_id Int
  lot_id     Int?
  tenant_id  Int

  reference String?                          // PV-RP-2026-001 — numéro légal du PV
  title     String?                          // Intitulé du PV (ex: "Réception provisoire Bât A")
  type      String  @default("PROVISIONAL")  // PROVISIONAL | FINAL
  status    String  @default("PENDING")
  // PENDING | SCHEDULED | IN_PROGRESS | ACCEPTED | ACCEPTED_WITH_RESERVES | REFUSED | WITHDRAWN

  planned_date      DateTime?                // Date prévisionnelle de la visite
  inspection_date   DateTime?                // Date effective de la visite physique
  accepted_at       DateTime?                // Date officielle de réception signée
  contra_visit_date DateTime?                // Date de contre-visite prévue (si réserves)

  warranty_months   Int      @default(12)    // Durée GPA en mois (12 mois légaux, loi Spinetta)
  warranty_end_date DateTime?                // Date de fin GPA = accepted_at + warranty_months

  amount_accepted Decimal? @db.Decimal(15, 2) // Montant des travaux réceptionnés
  penalty_amount  Decimal? @db.Decimal(15, 2) // Pénalités de retard déduites

  reserve_count        Int     @default(0)   // Nombre de réserves constatées
  notes                String? @db.NVarChar(Max)  // Observations générales (champ d'origine conservé)
  observations         String? @db.NVarChar(Max)  // Compte-rendu détaillé de la visite
  reserves_text        String? @db.NVarChar(Max)  // Liste formelle des réserves notifiées
  attendees            String? @db.NVarChar(Max)  // JSON: [{ name, role, company, signed }]

  signed_by_owner      Boolean @default(false)    // Le Maître d'Ouvrage a signé le PV
  signed_by_contractor Boolean @default(false)    // L'Entreprise a signé le PV
  document_url         String?                    // URL du PV signé (scan PDF)

  inspector_id Int?

  created_by Int?
  createdBy  User?       @relation("WorkAcceptanceCreatedBy",  fields: [created_by],   references: [id], onDelete: NoAction, onUpdate: NoAction)
  inspector  User?       @relation("WorkAcceptanceInspector",  fields: [inspector_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant     Tenant      @relation(fields: [tenant_id],         references: [id], onDelete: NoAction, onUpdate: NoAction)
  project    Project     @relation(fields: [project_id],        references: [id], onDelete: NoAction, onUpdate: NoAction)
  lot        ProjectLot? @relation(fields: [lot_id],            references: [id], onDelete: NoAction, onUpdate: NoAction)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([lot_id])
  @@index([project_id, status])
  @@index([tenant_id, status])
}

//////////////////////////////
// INCIDENT MANAGEMENT (AJOUT ULTRA IMPORTANT)
//////////////////////////////

model Incident {
  id          Int @id @default(autoincrement())
  project_id  Int
  task_id     Int?
  lot_id      Int?
  tenant_id   Int
  type        String  // SAFETY | QUALITY | DELAY | TECHNICAL | ENVIRONMENTAL
  severity    String  // LOW | MEDIUM | HIGH | CRITICAL
  status      String  // OPEN | IN_PROGRESS | RESOLVED | CLOSED

  title             String?
  description       String @db.NVarChar(Max)
  location          String?                     // Localisation sur le chantier
  incident_date     DateTime?                   // Date/heure de survenue (≠ created_at)
  root_cause        String? @db.NVarChar(Max)   // Analyse des causes racines (REX / prévention)
  corrective_action String? @db.NVarChar(Max)   // Action corrective mise en place
  cost_impact       Float?                      // Impact financier estimé
  delay_impact_days Int?                        // Impact planning en jours

  assigned_to_id Int?                           // Responsable de traitement
  assignedTo     User?       @relation("IncidentAssignedTo", fields: [assigned_to_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  resolved_at DateTime?

  created_by Int?
  createdBy  User?       @relation("IncidentCreatedBy", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant     Tenant      @relation(fields: [tenant_id],  references: [id], onDelete: NoAction, onUpdate: NoAction)
  project    Project     @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  task       Task?       @relation(fields: [task_id],    references: [id], onDelete: NoAction, onUpdate: NoAction)
  lot        ProjectLot? @relation(fields: [lot_id],     references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  @@index([tenant_id, project_id])
  @@index([status])
  @@index([created_at])
  @@index([lot_id])
  @@index([assigned_to_id])
}

//////////////////////////////
// DOCUMENTS + ARCHIVE
//////////////////////////////

model Document {
    
  id          Int @id @default(autoincrement())
  project_id  Int
  lot_id      Int?
  category    String @default("PLAN") // REPORT / CONTRACT
  name        String
  description String? @db.NVarChar(Max)
  is_archived Boolean @default(false)
  tenant_id Int

  tenant Tenant @relation(fields: [tenant_id], references: [id])
  project Project @relation(fields: [project_id], references: [id])
  lot     ProjectLot? @relation(fields: [lot_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  created_by Int?
  createdBy  User? @relation("DocumentCreatedBy", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  tags        String? @db.NVarChar(Max)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations inverses pour corriger les erreurs Prisma
  projectStocks ProjectStock[]
  goodsReceiptItems GoodsReceiptItem[]
  stockMovements StockMovement[]
  materialConsumptions MaterialConsumption[]
  projects         Project[] @relation("ProjectMainDocument")
  documentVersions DocumentVersion[] @relation("DocumentVersions")
  costTransactions CostTransaction[]

  @@index([lot_id])
}

model DocumentVersion {
  id          Int @id @default(autoincrement())
  document_id Int
  version     Int
  file_url    String
  file_size   Int?
  tenant_id   Int
  created_by  Int   // user_id
  createdBy   User     @relation("DocumentVersionCreatedBy", fields: [created_by], references: [id])
  comment     String? @db.NVarChar(Max)
  document Document @relation("DocumentVersions", fields: [document_id], references: [id], onDelete: NoAction)
  tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  @@index([document_id])
  @@index([created_by])
}

model Photo {
  id         Int @id @default(autoincrement())
  project_id Int
  file_url   String
  caption    String? @db.NVarChar(Max)
  taken_at   DateTime @default(now())
  tagged_entities String? @db.NVarChar(Max) // Remplacé Json par String pour compatibilité SQL Server
  tenant_id Int
  daily_log_id Int?
  daily_log DailyLog? @relation(fields: [daily_log_id], references: [id])
  tenant Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  project Project @relation(fields: [project_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  created_at DateTime @default(now())
}

model DocumentExchange {
  id         Int @id @default(autoincrement())
  project_id Int
  message    String @db.NVarChar(Max)
  file_url   String? 
  tenant_id Int
  created_by Int?
  createdBy  User? @relation("DocumentExchangeCreatedBy", fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
  project Project @relation(fields: [project_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  tenant Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
}

//////////////////////////////
// WORKFLOW (REAL ENGINE)
//////////////////////////////

model WorkflowDefinition {
  id   Int @id @default(autoincrement())
  name String
  tenant_id Int
  created_at DateTime @default(now())
  tenant Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  created_by Int?
  createdBy  User? @relation("WorkflowDefinitionCreatedBy", fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
  steps WorkflowStep[]
  instances WorkflowInstance[]
}


model WorkflowStep {
  currentInstances WorkflowInstance[] @relation("CurrentStepInstances")
  actions WorkflowAction[]
  id            Int @id @default(autoincrement())
  definition_id Int
  created_at DateTime @default(now())
  tenant_id Int
  tenant Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  name  String
  type  String // APPROVAL, TASK, AUTO
  order Int

  definition WorkflowDefinition @relation(fields: [definition_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  transitions_from WorkflowTransition[] @relation("WorkflowTransitionFrom")
  transitions_to   WorkflowTransition[] @relation("WorkflowTransitionTo")
}


model WorkflowTransition {
    created_at DateTime @default(now())
  id        Int @id @default(autoincrement())
  from_step_id Int
  to_step_id   Int

  condition String? // APPROVED, REJECTED, etc.
  tenant_id Int
  tenant Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  from WorkflowStep @relation("WorkflowTransitionFrom", fields: [from_step_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  to   WorkflowStep @relation("WorkflowTransitionTo", fields: [to_step_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@index([from_step_id])
  @@index([to_step_id])
}


model WorkflowInstance {
  id              Int @id @default(autoincrement())
  definition_id   Int
  project_id      Int

  current_step_id Int
  status          String // ACTIVE, COMPLETED, CANCELLED
  tenant_id Int
  tenant Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  entity_type String
  entity_id   Int
  created_at DateTime @default(now())

  project Project @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  definition  WorkflowDefinition @relation(fields: [definition_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  currentStep WorkflowStep       @relation("CurrentStepInstances", fields: [current_step_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  actions WorkflowAction[]

  @@index([definition_id])
  @@index([created_at])
  @@index([tenant_id, project_id])
  @@index([tenant_id, status])
  @@index([current_step_id, status])
}

model WorkflowAction {
  id           Int @id @default(autoincrement())
  instance_id  Int
  step_id      Int

  action   String // APPROVED, REJECTED
  comment  String? @db.NVarChar(Max)

  performed_by Int
  tenant_id Int
  created_at   DateTime @default(now())

  instance WorkflowInstance @relation(fields: [instance_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  step     WorkflowStep     @relation(fields: [step_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user     User             @relation("WorkflowActionPerformed", fields: [performed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant      Tenant @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  @@index([performed_by])
  @@index([instance_id])
  @@index([step_id])
}

//////////////////////////////
// AUDIT
//////////////////////////////

  model AuditLog {
  id          Int @id @default(autoincrement())
  user_id     Int
  tenant_id   Int
  user        User   @relation(fields: [user_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  tenant      Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  action      String
  entity_type String
  entity_id   String
  old_value   String? @db.NVarChar(Max) // Remplacé Json par String pour compatibilité SQL Server
  new_value   String? @db.NVarChar(Max) // Remplacé Json par String pour compatibilité SQL Server
  created_at   DateTime @default(now())
}    
  //////////////////////////////
  // DAILY LOGS
  //////////////////////////////

  model DailyLog {
    id          Int @id @default(autoincrement())
    project_id  Int
    date        DateTime
    weather     String?
    temperature Float?
    notes       String? @db.NVarChar(Max)
    tenant_id   Int
    created_by Int?
    createdBy  User? @relation("DailyLogCreatedBy", fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
    project Project @relation(fields: [project_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
    tenant      Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

    labor_entries    DailyLogLabor[]
    equipment_entries DailyLogEquipment[]
    material_entries DailyLogMaterial[]
    photos           Photo[]
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt
  }

  model DailyLogLabor {
    id            Int @id @default(autoincrement())
    daily_log_id  Int
    worker_name   String?
    hours         Float
    trade         String?
    daily_log DailyLog @relation(fields: [daily_log_id], references: [id])
  }

  model DailyLogEquipment {
    id            Int @id @default(autoincrement())
    daily_log_id  Int
    equipment_id  String?
    hours_used    Float
    daily_log DailyLog @relation(fields: [daily_log_id], references: [id])
  }

  model DailyLogMaterial {
    id            Int @id @default(autoincrement())
    daily_log_id  Int
    material_id   String?
    quantity      Float
    unit          String?
    daily_log DailyLog @relation(fields: [daily_log_id], references: [id])
    }

    //////////////////////////////
    // INSPECTIONS & PUNCH LIST
    //////////////////////////////

    model Inspection {
      id          Int @id @default(autoincrement())
      project_id  Int
      lot_id      Int?
      title       String
      type        String // "DAILY", "HOLD_POINT", "WITNESS_POINT", "FINAL"
      status      String // "SCHEDULED", "IN_PROGRESS", "PASSED", "FAILED"
      scheduled_date DateTime?
      completed_date DateTime?

      description      String? @db.NVarChar(Max) // Périmètre / contexte de l'inspection
      location         String?                   // Localisation sur l'ouvrage (Niv. R+3, Zone A...)
      reference_norm   String?                   // Référence DTU, Eurocode, article CCTP

      inspector_id Int?                          // Contrôleur assigné (OPC, MOE, bureau de contrôle)
      inspector    User? @relation("InspectionInspector", fields: [inspector_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

      tenant_id Int
      created_by Int?
      createdBy  User? @relation("InspectionCreatedBy", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
      project Project    @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
      lot     ProjectLot? @relation(fields: [lot_id],    references: [id], onDelete: NoAction, onUpdate: NoAction)
      tenant  Tenant      @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

      items InspectionItem[]
      created_at DateTime @default(now())
      updated_at DateTime @updatedAt

      @@index([lot_id])
      @@index([inspector_id])
      @@index([tenant_id, project_id])
    }

    model InspectionItem {
      id           Int @id @default(autoincrement())
      inspection_id Int
      order         Int     @default(0)          // Ordre dans la checklist
      category      String?                      // Regroupement : Structure, Étanchéité, Finitions...
      description   String @db.NVarChar(Max)
      result        String? // "PASS", "FAIL", "N/A"
      comment       String? @db.NVarChar(Max)
      inspection Inspection @relation(fields: [inspection_id], references: [id])
    }

    model PunchItem {
      id          Int @id @default(autoincrement())
      project_id  Int
      lot_id      Int?
      task_id     Int?                         // Tâche WBS liée (optionnel)

      title       String
      description String @db.NVarChar(Max)

      category    String  @default("QUALITY")  // QUALITY | SAFETY | FINISHING | STRUCTURAL | MEP
      priority    String  @default("MEDIUM")   // LOW | MEDIUM | HIGH | BLOCKING
      status      String  @default("OPEN")     // OPEN | IN_PROGRESS | SUBMITTED | VERIFIED | CLOSED | REJECTED

      location    String?                      // Localisation : Bât A, R+2, Zone Nord...
      image_urls  String? @db.NVarChar(Max)    // JSON array d'URLs photos (preuve opposable)

      assigned_to_id Int?                      // Responsable levée de réserve (User)
      assignedTo     User? @relation("PunchItemAssignedTo", fields: [assigned_to_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

      due_date    DateTime?
      resolved_at DateTime?

      tenant_id Int
      created_by Int?
      createdBy  User?       @relation("PunchItemCreatedBy", fields: [created_by],   references: [id], onDelete: NoAction, onUpdate: NoAction)
      project    Project     @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
      lot        ProjectLot? @relation(fields: [lot_id],     references: [id], onDelete: NoAction, onUpdate: NoAction)
      task       Task?       @relation(fields: [task_id],    references: [id], onDelete: NoAction, onUpdate: NoAction)
      tenant     Tenant      @relation(fields: [tenant_id],  references: [id], onDelete: NoAction, onUpdate: NoAction)

      created_at DateTime @default(now())
      updated_at DateTime @updatedAt

      @@index([lot_id])
      @@index([task_id])
      @@index([assigned_to_id])
      @@index([project_id, status])
      @@index([tenant_id, status])
      }

      //////////////////////////////
      // MEETINGS
      //////////////////////////////

      model Meeting {
        id          Int @id @default(autoincrement())
        project_id  Int
        tenant_id   Int
        title       String
        date        DateTime
        location    String?
        minutes     String?
        created_by Int?
        createdBy  User? @relation("MeetingCreatedBy", fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
        project Project @relation(fields: [project_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
        tenant Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
        
        created_at DateTime @default(now())
        updated_at DateTime @updatedAt

        attendees MeetingAttendee[]
      }

      model MeetingAttendee {
        id         Int @id @default(autoincrement())
        meeting_id Int
        user_id    Int?
        name       String? // pour les externes

        meeting Meeting @relation(fields: [meeting_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
        user    User?   @relation(fields: [user_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
            
        created_at DateTime @default(now())

    }


model CostType {
    created_at DateTime @default(now())
  code        String @id
  label       String

  transactions CostTransaction[]
}

model CostTransaction {
  id           Int @id @default(autoincrement())
  tenant_id    Int
  project_id   Int
  wbs_id       Int?

  type_code    String   // FK → CostType.code
  source_code  String   // FK → CostSource.code
  category_code String? // FK → CostCategory.code

  reference_id String   // id externe (invoice, contract, etc.)

  amount       Float
  currency     String

  document_id Int?
  document Document? @relation(fields: [document_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  created_by Int?
  createdBy  User? @relation("CostTransactionCreatedBy", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transaction_date DateTime
  created_at DateTime @default(now())

  project Project  @relation(fields: [project_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  wbs     WBSNode? @relation(fields: [wbs_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  tenant  Tenant  @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  type    CostType @relation(fields: [type_code], references: [code])

  @@index([tenant_id, project_id])
  @@index([wbs_id])
  @@index([type_code])
  @@index([transaction_date])
  projectStocks ProjectStock[]
}

model WeeklyReport {
  id          Int @id @default(autoincrement())
  project_id  Int
  tenant_id   Int

  week_start  DateTime
  week_end    DateTime

  overall_progress Float
  summary     String? @db.NVarChar(Max)

  prepared_by Int
  validated_by Int?

  preparedBy User @relation("PreparedBy", fields: [prepared_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
  validatedBy User? @relation("ValidatedBy", fields: [validated_by], references: [id], onUpdate: NoAction, onDelete: NoAction)

  status String // DRAFT / SUBMITTED / APPROVED

  created_at DateTime @default(now())
  created_by Int?
  createdBy  User? @relation("WeeklyReportCreatedBy", fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
  project Project @relation(fields: [project_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  tenant  Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  items WeeklyReportItem[]

  @@index([tenant_id, project_id])
}

model WeeklyReportItem {
  id Int @id @default(autoincrement())

  report_id Int
  task_id   Int?

  description String
  weekly_progress Float
  cumulative_progress Float

  comment String? @db.NVarChar(Max)

  report WeeklyReport @relation(fields: [report_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  task   Task?        @relation(fields: [task_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
}

model Permission {
  id    Int    @id @default(autoincrement())
  code  String @unique // "CREATE_PO", "APPROVE_INVOICE", etc.
  label String

  rolePermissions RolePermission[]
}

model Role {
  id        Int    @id @default(autoincrement())
  code      String @unique // Ajouté pour l'upsert et l'identification métier
  name      String // ADMIN, PM, ENGINEER...
  description String? // Ajouté pour permettre la description métier
  tenant_id Int?

  tenant Tenant? @relation(fields: [tenant_id], references: [id])

  rolePermissions RolePermission[]
  userRoles       UserRole[]
}

model RolePermission {
  role_id       Int
  permission_id Int

  role       Role       @relation(fields: [role_id], references: [id])
  permission Permission @relation(fields: [permission_id], references: [id])

  @@id([role_id, permission_id])
  @@index([role_id])
  @@index([permission_id])
}

model UserRole {
  id         Int @id @default(autoincrement())
  user_id    Int
  role_id    Int

  tenant_id  Int?
  project_id Int?

  user User @relation(fields: [user_id], references: [id])
  role Role @relation(fields: [role_id], references: [id])

  tenant  Tenant?  @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  project Project? @relation(fields: [project_id], references: [id])

  @@index([user_id, tenant_id])
  @@index([user_id, project_id])
  @@unique([user_id, role_id, project_id])
}

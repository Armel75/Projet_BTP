generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

//////////////////////////////
// CORE + MULTI TENANT
//////////////////////////////

model Tenant {
  id   String @id @default(uuid())
  name String

  projects Project[]
  users    User[]
}

model User {
  id            String @id @default(uuid())
  firstname     String
  lastname      String
  email         String @unique
  password_hash String
  tenant_id     String

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  projectRoles UserProjectRole[]
}

//////////////////////////////
// PROJECT
//////////////////////////////

model Project {
  id           String @id @default(uuid())
  code         String @unique
  title        String
  status       String

  tenant_id String
  tenant    Tenant @relation(fields: [tenant_id], references: [id])

  start_date DateTime?
  end_date   DateTime?

  budget_initial Float
  currency       String
  location       String

  lots     ProjectLot[]
  wbs      WBSNode[]
  documents Document[]

  incidents Incident[]
  tenders   Tender[]
}

//////////////////////////////
// WBS
//////////////////////////////

model WBSNode {
  id         String @id @default(uuid())
  project_id String
  parent_id  String?

  code  String
  name  String
  level Int

  project Project @relation(fields: [project_id], references: [id])
}

//////////////////////////////
// TASKS
//////////////////////////////

model Task {
  id         String @id @default(uuid())
  project_id String
  wbs_id     String?

  title    String
  status   String
  progress Float

  planned_start DateTime?
  planned_end   DateTime?

  project Project @relation(fields: [project_id], references: [id])

  dependencies TaskDependency[]
  assignments  TaskAssignment[]
}

//////////////////////////////
// APPROVISIONNEMENT COMPLET
//////////////////////////////

model Supplier {
  id        String @id @default(uuid())
  tenant_id String
  name      String
}

model Tender {
  id         String @id @default(uuid())
  project_id String
  title      String
  status     String

  bids TenderBid[]
}

model TenderBid {
  id         String @id @default(uuid())
  tender_id  String
  supplier_id String
  amount     Float

  tender Tender @relation(fields: [tender_id], references: [id])
}

model PurchaseOrder {
  id          String @id @default(uuid())
  project_id  String
  supplier_id String

  status String

  supplier Supplier @relation(fields: [supplier_id], references: [id])
}

model Delivery {
  id          String @id @default(uuid())
  project_id  String
  type        String // INTERNAL / EXTERNAL
  status      String
  delivered_at DateTime?
}

//////////////////////////////
// FINANCE / BUDGET
//////////////////////////////

model BudgetLine {
  id         String @id @default(uuid())
  project_id String
  category   String
  planned    Float
  actual     Float
}

model Invoice {
  id         String @id @default(uuid())
  project_id String
  amount     Float
  status     String
}

model Payment {
  id         String @id @default(uuid())
  invoice_id String
  amount     Float
  date       DateTime

  invoice Invoice @relation(fields: [invoice_id], references: [id])
}

//////////////////////////////
// QUALITY / CONTROL
//////////////////////////////

model ControlReport {
  id         String @id @default(uuid())
  project_id String
  task_id    String?

  status  String
  comment String
}

model WorkAcceptance {
  id         String @id @default(uuid())
  project_id String
  status     String
  accepted_at DateTime?
}

//////////////////////////////
// INCIDENT MANAGEMENT (AJOUT ULTRA IMPORTANT)
//////////////////////////////

model Incident {
  id         String @id @default(uuid())
  project_id String
  task_id    String?

  type       String  // SAFETY / QUALITY / DELAY / TECHNICAL
  severity   String  // LOW / MEDIUM / HIGH / CRITICAL
  status     String  // OPEN / IN_PROGRESS / RESOLVED / CLOSED

  description String

  created_at DateTime @default(now())
  resolved_at DateTime?

  project Project @relation(fields: [project_id], references: [id])
  task    Task?   @relation(fields: [task_id], references: [id])
}

//////////////////////////////
// DOCUMENTS + ARCHIVE
//////////////////////////////

model Document {
  id         String @id @default(uuid())
  project_id String

  name     String
  file_url String
  version  Int

  is_archived Boolean @default(false)

  project Project @relation(fields: [project_id], references: [id])
}

model DocumentExchange {
  id         String @id @default(uuid())
  project_id String
  message    String
  file_url   String?
}

//////////////////////////////
// WORKFLOW (REAL ENGINE)
//////////////////////////////

model WorkflowInstance {
  id         String @id @default(uuid())
  project_id String
  step       String
  status     String
}

//////////////////////////////
// AUDIT
//////////////////////////////

model AuditLog {
  id          String @id @default(uuid())
  user_id     String
  action      String
  entity_type String
  entity_id   String
  old_value   Json?
  new_value   Json?
  created_at  DateTime @default(now())
}

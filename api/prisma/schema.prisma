model ControlReport {
  id          Int @id @default(autoincrement())
  project_id  Int
  task_id     Int?
  lot_id      Int?
  tenant_id   Int
  reference   String
  title       String?
  type        String  @default("QUALITY") // QUALITY | SAFETY | COMPLIANCE | TECHNICAL
  category    String? // INTERNAL_AUDIT | EXTERNAL_AUDIT | CLIENT_WALKDOWN | REGULATORY
  status      String  @default("DRAFT")
  // DRAFT | OPEN | UNDER_REVIEW | ACTION_REQUIRED | RESOLVED | APPROVED | REJECTED | CLOSED
  initial_status String? // Statut initial au moment de la creation
  severity    String  @default("MEDIUM") // LOW | MEDIUM | HIGH | CRITICAL
  priority    String  @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  discipline  String?
  sub_discipline String?
  location    String?
  zone_code   String?
  latitude    Float?
  longitude   Float?

  source_channel String? @default("MANUAL") // MANUAL | MOBILE | IMPORT | API
  inspection_method String? // VISUAL | MEASURED | TESTED | DOCUMENT_REVIEW

  observed_by_name String?
  observed_by_company String?

  report_date DateTime?
  due_date    DateTime?
  target_response_at DateTime?
  target_resolution_at DateTime?
  first_response_at DateTime?
  last_status_changed_at DateTime?
  resolved_at DateTime?
  closed_at   DateTime?
  comment     String @db.NVarChar(Max)
  root_cause  String? @db.NVarChar(Max)
  corrective_action_summary String? @db.NVarChar(Max)
  preventive_action_summary String? @db.NVarChar(Max)
  closure_summary String? @db.NVarChar(Max)

  assigned_to_id Int?

  sla_breached Boolean @default(false)
  escalation_level Int @default(0)

  open_actions_count Int @default(0)
  evidence_count Int @default(0)

  revision_no Int @default(1)

  is_archived Boolean @default(false)
  archived_at DateTime?

  approved_by     Int?
  approved_at     DateTime?
  approval_workflow_status String? @default("DRAFT") // DRAFT | IN_REVIEW | APPROVED | REJECTED | ARCHIVED
  rejected_reason String? @db.NVarChar(Max)

  budgetLines BudgetLine[]
  created_by  Int?
  createdBy   User?       @relation("ControlReportCreatedBy", fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
  approvedBy  User?       @relation("ControlReportApprovedBy", fields: [approved_by], references: [id], onUpdate: NoAction, onDelete: NoAction)

  project Project     @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant  Tenant      @relation(fields: [tenant_id],  references: [id], onDelete: NoAction, onUpdate: NoAction)
  task    Task?       @relation(fields: [task_id],    references: [id], onDelete: NoAction, onUpdate: NoAction)
  lot     ProjectLot? @relation(fields: [lot_id],     references: [id], onDelete: NoAction, onUpdate: NoAction)

  actions     ControlReportAction[]
  attachments ControlReportAttachment[]
  status_history ControlReportStatusHistory[]
  checklist_items ControlReportChecklistItem[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([tenant_id, reference])
  @@index([tenant_id, project_id])
  @@index([status])
  @@index([severity, status])
  @@index([priority, status])
  @@index([report_date])
  @@index([due_date])
  @@index([target_resolution_at])
  @@index([approval_workflow_status])
  @@index([assigned_to_id, status])
  @@index([approved_by])
  @@index([lot_id])
  @@index([is_archived])
}

model ControlReportAction {

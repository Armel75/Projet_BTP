  //////////////////////////////
  // CONTRACTS & CHANGE MANAGEMENT
  //////////////////////////////

  model Contract {
    id             Int @id @default(autoincrement())
    project_id     Int
    supplier_id    Int
    type           String    // OWNER | SUBCONTRACT | SUPPLY | CONSULTING
    title          String                        // Intitulé / objet du marché (obligatoire)
    reference      String
    description    String?   @db.NVarChar(Max)   // Objet détaillé du marché
    category       String?                       // TRAVAUX | FOURNITURES | SERVICES | MOE | ETUDES
    status         String    // DRAFT | PENDING_SIGNATURE | APPROVED | EXECUTED | SUSPENDED | TERMINATED | CLOSED
    amount         Decimal   @db.Decimal(15, 2) @default(0)  // Montant initial du contrat
    signed_at      DateTime?                     // Date de signature
    executed_at    DateTime?
    start_date     DateTime?
    end_date       DateTime?
    retention_pct  Float?

    advance_payment_pct    Float?                // % d'avance forfaitaire (pratique BTP)
    advance_payment_amount Decimal? @db.Decimal(15, 2)  // Montant de l'avance versée
    price_revision_index   String?               // Indice de révision des prix (BT01, TP01, ICC...)
    payment_terms          Int?                  // Délai de paiement légal en jours (30, 45...)
    document_id            Int?                  // Lien vers le Document structuré

    approved_by        Int?
    approved_at        DateTime?
    terminated_at      DateTime?
    termination_reason String? @db.NVarChar(Max)

    currency       String
    is_archived    Boolean  @default(false)
    archived_at    DateTime?
    tenant_id      Int

    supplier   Supplier  @relation(fields: [supplier_id], references: [id])
    tenant     Tenant    @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
    project    Project   @relation(fields: [project_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
    approvedBy User?     @relation("ContractApprovedBy", fields: [approved_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
    document   Document? @relation("ContractDocument", fields: [document_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

    line_items    ContractLineItem[]
    change_orders ChangeOrder[]
    invoices      Invoice[]
    situationsTravaux SituationTravaux[]
    lots          ProjectLot[] @relation("LotContract")
    created_by Int?
    createdBy  User? @relation("ContractCreatedBy", fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)

    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    @@unique([tenant_id, reference])
    @@index([tenant_id, project_id])
    @@index([status])
    @@index([created_at])
    @@index([supplier_id])
  }


  model ContractLineItem {
    id          Int @id @default(autoincrement())
    contract_id Int
    wbs_id      Int?
    lot_id      Int?
    order_index Int     @default(0)              // Numérotation et ordre d'affichage
    description String  @db.NVarChar(Max)
    category    String?                          // Corps d'état / nature de prestation
    quantity    Decimal @db.Decimal(15, 4) @default(0)
    unit        String
    unit_price  Decimal @db.Decimal(15, 2) @default(0)
    total_price Decimal @db.Decimal(15, 2) @default(0)

    progress_pct  Float   @default(0)            // Avancement de la ligne (0–100)
    billed_amount Decimal @db.Decimal(15, 2) @default(0)  // Montant déjà facturé sur cette ligne

    tenant_id  Int
    status     String   // APPROVED | PENDING_APPROVAL | REJECTED
    created_by Int?

    tenant    Tenant      @relation(fields: [tenant_id],   references: [id])
    contract  Contract    @relation(fields: [contract_id], references: [id])
    wbs_node  WBSNode?    @relation(fields: [wbs_id],      references: [id])
    lot       ProjectLot? @relation(fields: [lot_id],      references: [id], onUpdate: NoAction, onDelete: NoAction)
    createdBy User?       @relation("ContractLineItemCreatedBy", fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)

    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    @@index([contract_id])
    @@index([lot_id])
  }

  model ChangeOrder {
    id          Int @id @default(autoincrement())
    project_id  Int
    contract_id Int
    lot_id      Int?
    number      String
    title       String                        // Objet de l'OdS (obligatoire en BTP)
    reason      String? @db.NVarChar(Max)     // Motif / cause
    description String  @db.NVarChar(Max)
    status      String  // "PENDING_APPROVAL" | "APPROVED" | "REJECTED"
    amount      Float
    impact_days Int?                          // Impact sur le planning (jours)
    approved_at DateTime?
    tenant_id   Int
    created_by  Int?
    createdBy   User?       @relation("ChangeOrderCreatedBy",  fields: [created_by],  references: [id], onUpdate: NoAction, onDelete: NoAction)
    tenant      Tenant      @relation(fields: [tenant_id],      references: [id], onUpdate: NoAction, onDelete: NoAction)
    project     Project     @relation(fields: [project_id],     references: [id], onUpdate: NoAction, onDelete: NoAction)
    contract    Contract    @relation(fields: [contract_id],    references: [id], onUpdate: NoAction, onDelete: NoAction)
    lot         ProjectLot? @relation(fields: [lot_id],         references: [id], onUpdate: NoAction, onDelete: NoAction)
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt
    @@index([lot_id])
  }

    //////////////////////////////
    // RFI & SUBMITTALS
    //////////////////////////////

    model RFI {
      id         Int @id @default(autoincrement())
      project_id Int
      tenant_id  Int

      // ─── Identification ──────────────────────────────────────────────
      number    String   // ex: RFI-001
      reference String?  // Référence client / MOE

      // ─── Classification ──────────────────────────────────────────────
      category   String  @default("CLARIFICATION")
      // CLARIFICATION | DESIGN_CHANGE | SITE_CONDITION | SUBSTITUTION | COORDINATION | SAFETY
      discipline String?
      // STRUCTURE | GROS_OEUVRE | CHARPENTE | FACADES | SECOND_OEUVRE | MEP | VRD | PAYSAGE
      lot_id     Int?

      // ─── Contenu ─────────────────────────────────────────────────────
      subject      String  @db.NVarChar(Max)
      question     String  @db.NVarChar(Max)
      drawing_ref  String?  // Référence plan/CCTP
      spec_section String?  // Section CCTP concernée

      // ─── Workflow ────────────────────────────────────────────────────
      status   String @default("OPEN")
      // DRAFT | OPEN | UNDER_REVIEW | ANSWERED | CLOSED | CANCELLED
      priority String @default("NORMAL")
      // URGENT | HIGH | NORMAL | LOW

      // ─── Acteurs ─────────────────────────────────────────────────────
      submitted_by Int?
      assigned_to  Int?
      reviewed_by  Int?

      // ─── Réponse ─────────────────────────────────────────────────────
      answer            String?  @db.NVarChar(Max)  // brouillon
      official_response String?  @db.NVarChar(Max)  // réponse formelle
      answered_date     DateTime?
      closed_date       DateTime?

      // ─── Délai contractuel ───────────────────────────────────────────
      due_date DateTime?

      // ─── Impacts ─────────────────────────────────────────────────────
      cost_impact          Boolean @default(false)
      cost_impact_amount   Float?
      schedule_impact      Boolean @default(false)
      schedule_impact_days Int?

      // ─── Diffusion ───────────────────────────────────────────────────
      distribution_list String?  // emails séparés par virgule

      // ─── Relations ───────────────────────────────────────────────────
      submittedBy User?       @relation("RfiSubmittedBy", fields: [submitted_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
      assignedTo  User?       @relation("RfiAssignedTo",  fields: [assigned_to],  references: [id], onDelete: NoAction, onUpdate: NoAction)
      reviewedBy  User?       @relation("RfiReviewedBy",  fields: [reviewed_by],  references: [id], onDelete: NoAction, onUpdate: NoAction)
      tenant      Tenant      @relation(fields: [tenant_id],  references: [id], onDelete: NoAction, onUpdate: NoAction)
      project     Project     @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
      lot         ProjectLot? @relation(fields: [lot_id],     references: [id], onDelete: NoAction, onUpdate: NoAction)

      created_at DateTime @default(now())
      updated_at DateTime @updatedAt

      comments RFIComment[]

      @@index([tenant_id, project_id])
      @@index([status])
      @@index([priority, status])
      @@index([due_date])
      @@index([created_at])
    }

    model RFIComment {
      id      Int  @id @default(autoincrement())
      rfi_id  Int
      user_id Int?

      content      String  @db.NVarChar(Max)
      document_id  Int?

      rfi      RFI       @relation(fields: [rfi_id],     references: [id], onDelete: NoAction, onUpdate: NoAction)
      user     User?     @relation("RFICommentUser", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
      document Document? @relation("RFICommentDocument", fields: [document_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

      created_at DateTime @default(now())
      updated_at DateTime @updatedAt

      @@index([rfi_id])
    }

    model Submittal {
      id               Int @id @default(autoincrement())
      project_id       Int
      type             String // "MATERIAL_SUBMITTAL", "SHOP_DRAWING", "SAMPLE"
      title            String
      specification_ref String?
      status           String // "SUBMITTED", "APPROVED", "APPROVED_AS_NOTED", "REJECTED"
      due_date         DateTime?
      submission_date  DateTime?
      response_date    DateTime?
      tenant_id        Int

      tenant Tenant @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
      project Project    @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

      items SubmittalItem[]
      created_at DateTime @default(now())
      updated_at DateTime @updatedAt

      @@index([tenant_id, project_id])
      @@index([status])
      @@index([created_at])
    }

    model SubmittalItem {
      id          Int @id @default(autoincrement())
      submittal_id Int
      description  String @db.NVarChar(Max)
      document_id  Int?

  submittal Submittal  @relation(fields: [submittal_id], references: [id])
  document  Document? @relation("SubmittalItemDocument", fields: [document_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
}


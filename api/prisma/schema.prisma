model WorkAcceptance {
  id         Int @id @default(autoincrement())
  project_id Int
  lot_id     Int?
  tenant_id  Int

  reference String?                          // PV-RP-2026-001 — numéro légal du PV
  title     String?                          // Intitulé du PV (ex: "Réception provisoire Bât A")
  type      String  @default("PROVISIONAL")  // PROVISIONAL | FINAL
  status    String  @default("PENDING")
  // PENDING | SCHEDULED | IN_PROGRESS | ACCEPTED | ACCEPTED_WITH_RESERVES | REFUSED | WITHDRAWN

  planned_date      DateTime?                // Date prévisionnelle de la visite
  inspection_date   DateTime?                // Date effective de la visite physique
  accepted_at       DateTime?                // Date officielle de réception signée
  contra_visit_date DateTime?                // Date de contre-visite prévue (si réserves)

  warranty_months   Int      @default(12)    // Durée GPA en mois (12 mois légaux, loi Spinetta)
  warranty_end_date DateTime?                // Date de fin GPA = accepted_at + warranty_months

  amount_accepted Decimal? @db.Decimal(15, 2) // Montant des travaux réceptionnés
  penalty_amount  Decimal? @db.Decimal(15, 2) // Pénalités de retard déduites

  reserve_count        Int     @default(0)   // Nombre de réserves constatées
  notes                String? @db.NVarChar(Max)  // Observations générales (champ d'origine conservé)
  observations         String? @db.NVarChar(Max)  // Compte-rendu détaillé de la visite
  reserves_text        String? @db.NVarChar(Max)  // Liste formelle des réserves notifiées
  attendees            String? @db.NVarChar(Max)  // JSON: [{ name, role, company, signed }]

  signed_by_owner      Boolean @default(false)    // Le Maître d'Ouvrage a signé le PV
  signed_by_contractor Boolean @default(false)    // L'Entreprise a signé le PV
  document_id          Int?                       // Lien vers le Document structuré

  inspector_id Int?

  created_by Int?
  createdBy  User?       @relation("WorkAcceptanceCreatedBy",  fields: [created_by],   references: [id], onDelete: NoAction, onUpdate: NoAction)
  inspector  User?       @relation("WorkAcceptanceInspector",  fields: [inspector_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant     Tenant      @relation(fields: [tenant_id],         references: [id], onDelete: NoAction, onUpdate: NoAction)
  project    Project     @relation(fields: [project_id],        references: [id], onDelete: NoAction, onUpdate: NoAction)
  lot        ProjectLot? @relation(fields: [lot_id],            references: [id], onDelete: NoAction, onUpdate: NoAction)
  document   Document?   @relation("WorkAcceptanceDocument", fields: [document_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([lot_id])
  @@index([project_id, status])
  @@index([tenant_id, status])
}

//////////////////////////////
// INCIDENT MANAGEMENT (AJOUT ULTRA IMPORTANT)
//////////////////////////////

model Incident {
  id          Int @id @default(autoincrement())
  project_id  Int
  task_id     Int?
  lot_id      Int?
  tenant_id   Int
  type        String  // SAFETY | QUALITY | DELAY | TECHNICAL | ENVIRONMENTAL
  severity    String  // LOW | MEDIUM | HIGH | CRITICAL
  status      String  // OPEN | IN_PROGRESS | RESOLVED | CLOSED

  title             String?
  description       String @db.NVarChar(Max)
  location          String?                     // Localisation sur le chantier
  incident_date     DateTime?                   // Date/heure de survenue (≠ created_at)
  resolved_at       DateTime?                   // Date effective de résolution
  root_cause        String? @db.NVarChar(Max)   // Analyse des causes racines (REX / prévention)
  corrective_action String? @db.NVarChar(Max)   // Action corrective mise en place
  cost_impact       Float?                      // Impact financier estimé
  delay_impact_days Int?                        // Impact planning en jours

  is_archived    Boolean  @default(false)         // Soft delete — jamais supprimer un incident (conformité PPSPS)
  archived_at    DateTime?

  assigned_to_id Int?                           // Responsable de traitement
  created_by Int?
  createdBy      User?       @relation("IncidentCreatedBy", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedTo     User?       @relation("IncidentAssignedTo", fields: [assigned_to_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  tenant     Tenant      @relation(fields: [tenant_id],  references: [id], onDelete: NoAction, onUpdate: NoAction)
  project    Project     @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  task       Task?       @relation(fields: [task_id],    references: [id], onDelete: NoAction, onUpdate: NoAction)
  lot        ProjectLot? @relation(fields: [lot_id],     references: [id], onDelete: NoAction, onUpdate: NoAction)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  
  @@index([tenant_id, project_id])
  @@index([status])
  @@index([created_at])
  @@index([lot_id])
  @@index([assigned_to_id])
}

//////////////////////////////
// DOCUMENTS + ARCHIVE
//////////////////////////////

model Document {

  id          Int      @id @default(autoincrement())
  project_id  Int
  lot_id      Int?
  category    String   @default("PLAN") // PLAN | REPORT | CONTRACT | PERMIT | SPEC | DRAWING | OTHER
  name        String
  description String?  @db.NVarChar(Max)
  is_archived Boolean  @default(false)
  tenant_id   Int

  tenant    Tenant      @relation(fields: [tenant_id], references: [id])
  project   Project     @relation(fields: [project_id], references: [id])
  lot       ProjectLot? @relation(fields: [lot_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  supersedes Document?  @relation("DocumentSupersession", fields: [supersedes_document_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  supersededBy Document[] @relation("DocumentSupersession")
  created_by Int?
  createdBy  User?      @relation("DocumentCreatedBy", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  tags        String?  @db.NVarChar(Max)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // ── Lien optionnel vers un appel d'offres ──────────────────────────────
  tender_id       Int?                       // Document uploadé pour un AO précis
  tender          Tender?   @relation(fields: [tender_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  // ── Champs enrichis top 1% BTP ──────────────────────────────────────────
  reference       String?                    // Codification : ARC-STR-P-001-A
  discipline      String   @default("GENERAL") // ARCH | STRUCT | MEP | CIVIL | ELEC | PLUMB | GENERAL
  phase           String   @default("EXE")     // APD | PRO | DCE | EXE | RECEPTION | DOE
  status          String   @default("DRAFT")   // DRAFT | IN_REVIEW | APPROVED | SUPERSEDED
  revision        String   @default("A")       // Révision courante : A, B, C...
  file_url        String?                    // URL fichier courant (mis à jour à chaque nouvelle version)
  file_name       String?                    // Nom du fichier original
  file_size       Int?                       // Taille en octets
  file_type       String?                    // pdf | dwg | docx | xlsx | image | other
  confidentiality String   @default("INTERNAL") // PUBLIC | INTERNAL | RESTRICTED
  expiry_date     DateTime?                  // Pour permis, certifications

  // ── Version Control & Audit ────────────────────────────────────────────
  approval_status  String? @default("DRAFT") // DRAFT | IN_REVIEW | APPROVED | SUPERSEDED
  document_change_log String? @db.NVarChar(Max) // JSON: [{user_id, timestamp, action, version}]
  supersedes_document_id Int? // FK vers document antérieur (si révision)
  security_clearance_level String? @default("INTERNAL") // PUBLIC | INTERNAL | RESTRICTED

  // Relations inverses pour corriger les erreurs Prisma
  projectStocks        ProjectStock[]
  goodsReceiptItems    GoodsReceiptItem[]
  stockMovements       StockMovement[]
  materialConsumptions MaterialConsumption[]
  projects             Project[]        @relation("ProjectMainDocument")
  documentVersions     DocumentVersion[] @relation("DocumentVersions")
  costTransactions     CostTransaction[]
  tenderBids           TenderBid[]      @relation("TenderBidDocument")
  contracts            Contract[]       @relation("ContractDocument")
  rfiComments          RFIComment[]     @relation("RFICommentDocument")
  submittalItems       SubmittalItem[]  @relation("SubmittalItemDocument")
  workAcceptances      WorkAcceptance[] @relation("WorkAcceptanceDocument")

  @@index([lot_id])
  @@index([tender_id])
  @@index([project_id])
  @@index([status])
  @@index([supersedes_document_id])
}

model DocumentVersion {
  id          Int      @id @default(autoincrement())
  document_id Int
  version     Int
  file_url    String
  file_size   Int?
  tenant_id   Int
  created_by  Int      // user_id
  createdBy   User     @relation("DocumentVersionCreatedBy", fields: [created_by], references: [id])
  comment     String?  @db.NVarChar(Max)
  document    Document @relation("DocumentVersions", fields: [document_id], references: [id], onDelete: NoAction)
  tenant      Tenant   @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // ── Champs enrichis ─────────────────────────────────────────────────────
  file_name   String?                    // Nom du fichier original
  file_type   String?                    // pdf | dwg | docx | xlsx | image | other
  revision    String?                    // Label de révision : A, B, C...
  is_current  Boolean  @default(false)   // Version active du document
  status      String   @default("DRAFT") // DRAFT | IN_REVIEW | APPROVED
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([document_id])
  @@index([created_by])
}

model Photo {
  id         Int @id @default(autoincrement())
  project_id Int
  file_url   String
  caption    String? @db.NVarChar(Max)
  taken_at   DateTime @default(now())
  tagged_entities String? @db.NVarChar(Max) // Remplacé Json par String pour compatibilité SQL Server
  tenant_id Int
  daily_log_id Int?
  daily_log DailyLog? @relation(fields: [daily_log_id], references: [id])
  tenant Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  project Project @relation(fields: [project_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  created_at DateTime @default(now())
}

model DocumentExchange {
  id         Int @id @default(autoincrement())
  project_id Int
  message    String @db.NVarChar(Max)
  file_url   String? 
  tenant_id Int
  created_by Int?
  createdBy  User? @relation("DocumentExchangeCreatedBy", fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
  project Project @relation(fields: [project_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  tenant Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
}

//////////////////////////////
// WORKFLOW (REAL ENGINE)
//////////////////////////////

model WorkflowDefinition {
  id   Int @id @default(autoincrement())
  name String
  tenant_id Int
  created_at DateTime @default(now())
  tenant Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  created_by Int?
  createdBy  User? @relation("WorkflowDefinitionCreatedBy", fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
  steps WorkflowStep[]
  instances WorkflowInstance[]
}


model WorkflowStep {
  currentInstances WorkflowInstance[] @relation("CurrentStepInstances")
  actions WorkflowAction[]
  id            Int @id @default(autoincrement())
  definition_id Int
  created_at DateTime @default(now())
  tenant_id Int
  tenant Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  name  String
  type  String // APPROVAL, TASK, AUTO
  order Int

  definition WorkflowDefinition @relation(fields: [definition_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  transitions_from WorkflowTransition[] @relation("WorkflowTransitionFrom")
  transitions_to   WorkflowTransition[] @relation("WorkflowTransitionTo")
}


model WorkflowTransition {
    created_at DateTime @default(now())
  id        Int @id @default(autoincrement())
  from_step_id Int
  to_step_id   Int

  condition String? // APPROVED, REJECTED, etc.
  tenant_id Int
  tenant Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  from WorkflowStep @relation("WorkflowTransitionFrom", fields: [from_step_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  to   WorkflowStep @relation("WorkflowTransitionTo", fields: [to_step_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@index([from_step_id])
  @@index([to_step_id])
}


model WorkflowInstance {
  id              Int @id @default(autoincrement())
  definition_id   Int
  project_id      Int

  current_step_id Int
  status          String // ACTIVE, COMPLETED, CANCELLED
  tenant_id Int
  tenant Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  entity_type String
  entity_id   Int
  created_at DateTime @default(now())

  project Project @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  definition  WorkflowDefinition @relation(fields: [definition_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  currentStep WorkflowStep       @relation("CurrentStepInstances", fields: [current_step_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  actions WorkflowAction[]

  @@index([definition_id])
  @@index([created_at])
  @@index([tenant_id, project_id])
  @@index([tenant_id, status])
  @@index([current_step_id, status])
}

model WorkflowAction {
  id           Int @id @default(autoincrement())
  instance_id  Int
  step_id      Int

  action   String // APPROVED, REJECTED
  comment  String? @db.NVarChar(Max)

  performed_by Int
  tenant_id Int
  created_at   DateTime @default(now())

  instance WorkflowInstance @relation(fields: [instance_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  step     WorkflowStep     @relation(fields: [step_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user     User             @relation("WorkflowActionPerformed", fields: [performed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant      Tenant @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  
  @@index([performed_by])
  @@index([instance_id])
  @@index([step_id])
}

//////////////////////////////
// AUDIT
//////////////////////////////

  model AuditLog {
  id          Int @id @default(autoincrement())
  user_id     Int
  tenant_id   Int
  user        User   @relation(fields: [user_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  tenant      Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  action      String
  entity_type String
  entity_id   String
  old_value   String? @db.NVarChar(Max) // Remplacé Json par String pour compatibilité SQL Server
  new_value   String? @db.NVarChar(Max) // Remplacé Json par String pour compatibilité SQL Server
  created_at   DateTime @default(now())
}    
  //////////////////////////////
  // DAILY LOGS
  //////////////////////////////

  model DailyLog {
    id          Int @id @default(autoincrement())
    project_id  Int
    date        DateTime
    weather     String?
    temperature Float?
    notes       String? @db.NVarChar(Max)
    tenant_id   Int
    created_by Int?
    createdBy  User? @relation("DailyLogCreatedBy", fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
    project Project @relation(fields: [project_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
    tenant      Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

    labor_entries    DailyLogLabor[]
    equipment_entries DailyLogEquipment[]
    material_entries DailyLogMaterial[]
    task_progress    DailyLogTaskProgress[]
    photos           Photo[]
    is_archived      Boolean  @default(false)
    archived_at      DateTime?
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt
  }

  model DailyLogLabor {
    id            Int @id @default(autoincrement())
    daily_log_id  Int
    worker_name   String?
    hours         Float
    trade         String?
    daily_log DailyLog @relation(fields: [daily_log_id], references: [id])
  }

  model DailyLogEquipment {
    id            Int @id @default(autoincrement())
    daily_log_id  Int
    equipment_id  String?
    hours_used    Float
    daily_log DailyLog @relation(fields: [daily_log_id], references: [id])
  }

  model DailyLogMaterial {
    id            Int @id @default(autoincrement())
    daily_log_id  Int
    material_id   String?
    quantity      Float
    unit          String?
    daily_log DailyLog @relation(fields: [daily_log_id], references: [id])
  }

  model DailyLogTaskProgress {
    id                  Int     @id @default(autoincrement())
    daily_log_id        Int
    task_id             Int?                           // null pour les activités imprévues
    task_type           String  @default("planned")    // "planned" | "unplanned"
    task_title_custom   String? @db.NVarChar(500)      // titre si activité imprévue
    progress_percentage Int?                           // 0-100
    comment             String? @db.NVarChar(Max)      // observations terrain
    photos_url          String? @db.NVarChar(Max)      // JSON array de photos
    labor_data          String? @db.NVarChar(Max)      // JSON: [{worker_name, trade, hours}]
    equipment_data      String? @db.NVarChar(Max)      // JSON: [{equipment_name, hours_used}]
    material_data       String? @db.NVarChar(Max)      // JSON: [{material_name, quantity, unit}]

    daily_log DailyLog @relation(fields: [daily_log_id], references: [id], onDelete: Cascade)
    task      Task?    @relation(fields: [task_id],     references: [id], onDelete: NoAction, onUpdate: NoAction)

    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    @@index([daily_log_id])
    @@index([task_id])
  }

    //////////////////////////////
    // INSPECTIONS & PUNCH LIST
    //////////////////////////////

    model Inspection {
      id          Int @id @default(autoincrement())
      project_id  Int
      lot_id      Int?
      title       String
      type        String // "DAILY", "HOLD_POINT", "WITNESS_POINT", "FINAL"
      status      String // "SCHEDULED", "IN_PROGRESS", "PASSED", "FAILED"
      scheduled_date DateTime?
      completed_date DateTime?

      description      String? @db.NVarChar(Max) // Périmètre / contexte de l'inspection
      location         String?                   // Localisation sur l'ouvrage (Niv. R+3, Zone A...)
      reference_norm   String?                   // Référence DTU, Eurocode, article CCTP
      checklist_template_id Int? // FK vers modèle InspectionTemplate (futur)
      inspection_result String? // PASSED | FAILED | WITH_RESERVES
      evidence_photos_required Boolean @default(false) // Si true, validation = bloquante
      approval_workflow_status String? // DRAFT | IN_REVIEW | APPROVED | REJECTED | ARCHIVED
      date_scheduled DateTime? // Date planifiée contractuelle
      rework_required Boolean @default(false) // Reprise exigée après inspection

      inspector_id Int?                          // Contrôleur assigné (OPC, MOE, bureau de contrôle)
      inspector    User? @relation("InspectionInspector", fields: [inspector_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

      tenant_id Int
      created_by Int?
      createdBy  User? @relation("InspectionCreatedBy", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
      project Project    @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
      lot     ProjectLot? @relation(fields: [lot_id],    references: [id], onDelete: NoAction, onUpdate: NoAction)
      tenant  Tenant      @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

      items InspectionItem[]
      created_at DateTime @default(now())
      updated_at DateTime @updatedAt

      @@index([lot_id])
      @@index([inspector_id])
      @@index([tenant_id, project_id])
      @@index([approval_workflow_status])
    }

    model InspectionItem {
      id           Int @id @default(autoincrement())
      inspection_id Int
      order         Int     @default(0)          // Ordre dans la checklist
      category      String?                      // Regroupement : Structure, Étanchéité, Finitions...
      description   String @db.NVarChar(Max)
      result        String? // "PASS", "FAIL", "N/A"
      comment       String? @db.NVarChar(Max)
      inspection Inspection @relation(fields: [inspection_id], references: [id])
    }

    model PunchItem {
      id          Int @id @default(autoincrement())
      project_id  Int
      lot_id      Int?
      task_id     Int?                         // Tâche WBS liée (optionnel)

      title       String
      description String @db.NVarChar(Max)

      category    String  @default("QUALITY")  // QUALITY | SAFETY | FINISHING | STRUCTURAL | MEP
      priority    String  @default("MEDIUM")   // LOW | MEDIUM | HIGH | BLOCKING
      status      String  @default("OPEN")     // OPEN | IN_PROGRESS | SUBMITTED | VERIFIED | CLOSED | REJECTED

      location    String?                      // Localisation : Bât A, R+2, Zone Nord...
      image_urls  String? @db.NVarChar(Max)    // JSON array d'URLs photos (preuve opposable)

      assigned_to_id Int?                      // Responsable levée de réserve (User)
      assignedTo     User? @relation("PunchItemAssignedTo", fields: [assigned_to_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

      due_date    DateTime?
      resolved_at DateTime?

      tenant_id Int
      created_by Int?
      createdBy  User?       @relation("PunchItemCreatedBy", fields: [created_by],   references: [id], onDelete: NoAction, onUpdate: NoAction)
      project    Project     @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
      lot        ProjectLot? @relation(fields: [lot_id],     references: [id], onDelete: NoAction, onUpdate: NoAction)
      task       Task?       @relation(fields: [task_id],    references: [id], onDelete: NoAction, onUpdate: NoAction)
      tenant     Tenant      @relation(fields: [tenant_id],  references: [id], onDelete: NoAction, onUpdate: NoAction)

      created_at DateTime @default(now())
      updated_at DateTime @updatedAt

      @@index([tenant_id, project_id])
      @@index([lot_id])
      @@index([task_id])
      @@index([assigned_to_id])
      @@index([project_id, status])
      @@index([tenant_id, status])
      }

      //////////////////////////////
      // MEETINGS
      //////////////////////////////

      model Meeting {
        id          Int      @id @default(autoincrement())
        project_id  Int
        tenant_id   Int
        lot_id      Int?

        // ─── Identification ──────────────────────────────────────
        title       String
        reference   String?  // ex: CR-2026-042
        type        String   @default("CHANTIER")
        // CHANTIER | COORDINATION | SECURITE | OPR | VISA | CODIR | KICK_OFF

        // ─── Planification ───────────────────────────────────────
        date        DateTime
        end_date    DateTime?
        location    String?
        status      String   @default("PLANNED")
        // PLANNED | IN_PROGRESS | DONE | CANCELLED

        // ─── Contenu ─────────────────────────────────────────────
        agenda      String?  @db.NVarChar(Max)  // Ordre du jour
        minutes     String?  @db.NVarChar(Max)  // Compte-rendu / procès-verbal
        conclusion  String?  @db.NVarChar(Max)  // Conclusions & décisions

        // ─── Prochaine réunion ───────────────────────────────────
        next_meeting_date     DateTime?
        next_meeting_location String?

        // ─── Diffusion ───────────────────────────────────────────
        distribution_list String? // emails séparés par virgule

        // ─── Création ────────────────────────────────────────────
        created_by  Int?

        createdBy User?       @relation("MeetingCreatedBy", fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
        project   Project     @relation(fields: [project_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
        tenant    Tenant      @relation(fields: [tenant_id],  references: [id], onUpdate: NoAction, onDelete: NoAction)
        lot       ProjectLot? @relation(fields: [lot_id],    references: [id], onUpdate: NoAction, onDelete: NoAction)

        created_at DateTime @default(now())
        updated_at DateTime @updatedAt

        attendees   MeetingAttendee[]
        actionItems MeetingActionItem[]

        @@index([project_id])
        @@index([project_id, status])
        @@index([tenant_id, status])
      }

      model MeetingAttendee {
        id         Int @id @default(autoincrement())
        meeting_id Int
        user_id    Int?
        name       String?  // Pour les participants externes

        // ─── Enrichissement ──────────────────────────────────────
        status     String  @default("INVITED")
        // INVITED | PRESENT | ABSENT | EXCUSED | DELEGATED
        company    String? // Entreprise (pour les externes)
        role_title String? // Fonction/qualité (MOE, MO, BET Struct…)

        meeting Meeting @relation(fields: [meeting_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
        user    User?   @relation(fields: [user_id],    references: [id], onUpdate: NoAction, onDelete: NoAction)

        created_at DateTime @default(now())
        updated_at DateTime @updatedAt

        @@index([meeting_id])
      }

      model MeetingActionItem {
        id         Int @id @default(autoincrement())
        meeting_id Int
        tenant_id  Int

        subject          String
        responsible_id   Int?     // User interne responsable
        responsible_name String?  // Pilote externe / prestataire inconnu
        glpi_ticket_id   Int?     // Ticket GLPI associe a l'action
        due_date         DateTime?
        status           String   @default("OPEN")
        // OPEN | IN_PROGRESS | CLOSED | CANCELLED
        comment          String?  @db.NVarChar(Max)

        created_by Int?

        meeting     Meeting  @relation(fields: [meeting_id],    references: [id], onUpdate: NoAction, onDelete: NoAction)
        tenant      Tenant   @relation(fields: [tenant_id],     references: [id], onUpdate: NoAction, onDelete: NoAction)
        responsible User?    @relation("ActionItemResponsible", fields: [responsible_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
        glpiTicket  Ticket?  @relation(fields: [glpi_ticket_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
        createdBy   User?    @relation("ActionItemCreatedBy",   fields: [created_by],     references: [id], onUpdate: NoAction, onDelete: NoAction)

        created_at DateTime @default(now())
        updated_at DateTime @updatedAt

        @@index([meeting_id])
        @@index([tenant_id, status])
        @@index([responsible_id, status])
        @@index([glpi_ticket_id])
      }


model CostType {
    created_at DateTime @default(now())
  code        String @id
  label       String

  transactions CostTransaction[]
}

model CostTransaction {
  id           Int @id @default(autoincrement())
  tenant_id    Int
  project_id   Int
  wbs_id       Int?

  type_code    String   // FK → CostType.code
  source_code  String   // FK → CostSource.code
  category_code String? // FK → CostCategory.code

  reference_id String   // id externe (invoice, contract, etc.)

  amount       Float
  currency     String

  document_id Int?
  document Document? @relation(fields: [document_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  created_by Int?
  createdBy  User? @relation("CostTransactionCreatedBy", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  transaction_date DateTime
  created_at DateTime @default(now())

  project Project  @relation(fields: [project_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  wbs     WBSNode? @relation(fields: [wbs_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  tenant  Tenant  @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  type    CostType @relation(fields: [type_code], references: [code])

  @@index([tenant_id, project_id])
  @@index([wbs_id])
  @@index([type_code])
  @@index([transaction_date])
  projectStocks ProjectStock[]
}

model WeeklyReport {
  id          Int @id @default(autoincrement())
  project_id  Int
  tenant_id   Int

  week_start  DateTime
  week_end    DateTime

  overall_progress Float
  summary     String? @db.NVarChar(Max)

  prepared_by Int
  validated_by Int?

  preparedBy User @relation("PreparedBy", fields: [prepared_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
  validatedBy User? @relation("ValidatedBy", fields: [validated_by], references: [id], onUpdate: NoAction, onDelete: NoAction)

  status String // DRAFT / SUBMITTED / APPROVED

  created_at DateTime @default(now())
  created_by Int?
  createdBy  User? @relation("WeeklyReportCreatedBy", fields: [created_by], references: [id], onUpdate: NoAction, onDelete: NoAction)
  project Project @relation(fields: [project_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  tenant  Tenant @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)

  items WeeklyReportItem[]

  @@index([tenant_id, project_id])
}

model WeeklyReportItem {
  id Int @id @default(autoincrement())

  report_id Int
  task_id   Int?

  description String
  weekly_progress Float
  cumulative_progress Float

  comment String? @db.NVarChar(Max)

  report WeeklyReport @relation(fields: [report_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  task   Task?        @relation(fields: [task_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
}

model Permission {
  id    Int    @id @default(autoincrement())
  code  String @unique // "CREATE_PO", "APPROVE_INVOICE", etc.
  label String

  rolePermissions RolePermission[]
}

model Role {
  id        Int    @id @default(autoincrement())
  code      String @unique // Ajouté pour l'upsert et l'identification métier
  name      String // ADMIN, PM, ENGINEER...
  description String? // Ajouté pour permettre la description métier
  tenant_id Int?

  tenant Tenant? @relation(fields: [tenant_id], references: [id])

  rolePermissions RolePermission[]
  userRoles       UserRole[]
}

model RolePermission {
  role_id       Int
  permission_id Int

  role       Role       @relation(fields: [role_id], references: [id])
  permission Permission @relation(fields: [permission_id], references: [id])

  @@id([role_id, permission_id])
  @@index([role_id])
  @@index([permission_id])
}

model UserRole {
  id         Int @id @default(autoincrement())
  user_id    Int
  role_id    Int

  tenant_id  Int?
  project_id Int?

  user User @relation(fields: [user_id], references: [id])
  role Role @relation(fields: [role_id], references: [id])

  tenant  Tenant?  @relation(fields: [tenant_id], references: [id], onUpdate: NoAction, onDelete: NoAction)
  project Project? @relation(fields: [project_id], references: [id])

  @@index([user_id, tenant_id])
  @@index([user_id, project_id])
  @@unique([user_id, role_id, project_id])
}
